        //método que va a tomar la raíz y mostrar las categorias
        public static void OP(Componente root)
        {
            //llamada a los hijos de la reiz que son las gamas
            var categorias = root.ObtenerHijos();

            //lista de opciones del menú
            //enumerar las opciones
            int g = 1;

            //titulo para las opciones
            Console.WriteLine("Gamas disponibles:");
            //recorre la lista
            foreach (var cat in categorias)
            {
                //muestra el nombre de cada elemento de las categorías
                Console.WriteLine(g + "- " + cat.Nombre);
                g++; //incremento para el siguiente # de opcion
            }
            Console.WriteLine("4. Salir");

            //se muestran los productos
            Console.Write("Elige una categoría: ");
            int p = int.Parse(Console.ReadLine());
            //verifica que sea una opcion valida
            if (p > 0 && p <= categorias.Count)
            {
                elementoos(categorias[ p - 1]);
            }
        }

        //método para mostrar los elementos de acuerdo a su categoria
        public static void elementoos(Componente categoria)
        {
            //llama a los elementos de la categoria
            var elementos = categoria.ObtenerHijos();

            //mostrar la categoria
            Console.WriteLine($"\n\nProductos de la categoría {categoria.Nombre}: " );

            //muestra el nombre de la categoria
            int op = 1;
            //recorre la lista
            foreach (var e in elementos)
            {
                //muestra el nombre de cada elemento de las categorías
                Console.WriteLine(op + "- " + e.Nombre);
                op++; //incremento para el siguiente # de opcion
            }
            Console.WriteLine("5. Salir");

            //el usuario elige un producto
            Console.Write("Elija un producto: ");
            int p = int.Parse(Console.ReadLine());

            //verifica que exista
            if (p > 0 && p <= elementos.Count)
            {
                var e = elementos[p - 1];

                Console.WriteLine($"Nombre: {e.Nombre}");
                Console.WriteLine($"Descripción: {e.ObtenerDescrip}");
                Console.WriteLine($"Precio: ${e.ObtenerPrecio}");

                Console.WriteLine("\nPresiona para reelegir");
                Console.ReadKey();
            }
        }
